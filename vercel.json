{
  "buildCommand": "cd react-app && npm install -g pnpm && pnpm install && pnpm run build",
  "outputDirectory": "react-app/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
